# Copia questo file in `.env.local` e inserisci la tua chiave.
# .env.local è gitignored: la chiave non finirà nel repo.
# Chiave Google Maps JavaScript API con Places API abilitato,
# ristretta per referrer (http://localhost:5173 in sviluppo).
VITE_GOOGLE_MAPS_API_KEY=

# URL del backend PHP (convertitore/validatore/upload) in PRODUZIONE.
# In sviluppo lascialo vuoto (si usa il proxy /api verso :8080).
# Su isotype.org impostalo al path reale di json-xml/index.php, es.
# VITE_API_BASE=../../json-xml/index.php   (se carichi ws-admin/ preservando la struttura)
VITE_API_BASE=
